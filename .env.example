# ══════════════════════════════════════════════════════════════
# HPC 平台配置样例文件
# 复制为 .env 并填写实际值后启动后端
# ══════════════════════════════════════════════════════════════

# ── 服务器 ────────────────────────────────────────────────────
SERVER_PORT=8080

# ── LDAP ──────────────────────────────────────────────────────
LDAP_HOST=192.168.x.x
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_SKIP_VERIFY=false
LDAP_BIND_DN=cn=Manager,dc=example,dc=com
LDAP_BIND_PASSWORD=your-ldap-password
LDAP_BASE_DN=dc=example,dc=com
LDAP_USER_BASE_DN=ou=people,dc=example,dc=com
LDAP_GROUP_BASE_DN=ou=group,dc=example,dc=com

# ── UID/GID 范围 ───────────────────────────────────────────────
UID_MIN=1000
UID_MAX=65000
GID_MIN=1000
GID_MAX=65000

# ── JWT ───────────────────────────────────────────────────────
# 生产环境请使用足够长的随机字符串，例如：openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

# ── 开发模式（生产必须为 false）────────────────────────────────
DEV_MODE=false
# DEV_USER=admin
# DEV_USER_UID=1000
# DEV_USER_IS_ADMIN=true

# ── Slurm REST API ────────────────────────────────────────────
SLURM_REST_URL=http://slurm-host:6820
SLURM_API_VERSION=v0.0.43
SLURM_ADMIN_USER=root
SLURM_JWT_KEY=your-slurm-jwt-key
SLURM_JWT_LIFESPAN=86400
# SLURM_CLUSTER_NAME=

# ── 监控（Prometheus）────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090

# ── Web Shell ─────────────────────────────────────────────────
# JSON 数组，配置可连接的节点列表
WEBSHELL_NODES=[{"name":"ln0","host":"192.168.x.x","port":22,"description":"登录节点","enabled":true}]

# ── 文件管理 ──────────────────────────────────────────────────
FILEMANAGER_BASE_PATH=/home
HOME_BASE_PATH=/home
# QUOTA_FS_TYPE=xfs
# QUOTA_PATH=/home

# ── 远程桌面 ──────────────────────────────────────────────────
DESKTOP_PARTITION=your-partition
DESKTOP_SSH_KEY=/root/.ssh/id_rsa
DESKTOP_SSH_USER=root
DESKTOP_SSH_PORT=22

# ── AI 问答 ───────────────────────────────────────────────────
# 兼容 OpenAI API 格式，可接入 DeepSeek / MiniMax / GPT 等
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=your-api-key
AI_MODEL=gpt-4o-mini
AI_SYSTEM_PROMPT=你是一个 HPC 高性能计算集群的应用助手，专门帮助用户解答并行计算（MPI/OpenMP）、科学软件使用（Python/R/MATLAB/GROMACS/VASP等）、编程环境配置、作业脚本编写等问题。回答简洁专业，用中文回答。不涉及集群运维管理内容。

# ── AI 知识库（Obsidian Vault）────────────────────────────────
# 问答记录写入目录，用 Obsidian 打开此目录即可查阅历史问答
# 留空则默认写到 ./knowledge/vault
OBSIDIAN_VAULT_DIR=./knowledge/vault

# ── 日志 ──────────────────────────────────────────────────────
LOG_FILE=./logs/slurm-web.log
# AUDIT_LOG_DIR=./logs/audit

# ── 前端运行时注入（/config.js）──────────────────────────────
# 留空表示同域由 nginx 代理；跨域部署时填写完整后端 URL
# PUBLIC_API_URL=http://your-server-ip:8080
# CLIENT_DIST_DIR=/opt/hpc-platform/clients
