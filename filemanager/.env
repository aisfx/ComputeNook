# 文件管理服务配置

# 服务端口
FILEMANAGER_PORT=8081

# 基础路径（文件管理的根目录）
# 用户只能访问此路径及其子目录
# 设置为 / 允许访问所有目录（不推荐生产环境）
# 设置为 /home 只允许访问 /home 目录
FILEMANAGER_BASE_PATH=/

# JWT 密钥（必须与主后端服务保持一致）
JWT_SECRET=xK8hL9mP2qR5sV7wY4zN6bE3tA1cF9gJ2dM4nP6rS8uV

# CORS 配置
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
