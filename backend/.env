# LDAP 配置
LDAP_HOST=192.168.5.250
LDAP_PORT=30833
LDAP_USE_SSL=false
LDAP_SKIP_VERIFY=false
LDAP_BIND_DN=cn=Manager,dc=thhpc,dc=cn
LDAP_BIND_PASSWORD=secret
LDAP_BASE_DN=dc=thhpc,dc=cn
LDAP_USER_BASE_DN=ou=people,dc=thhpc,dc=cn
LDAP_GROUP_BASE_DN=ou=group,dc=thhpc,dc=cn

# UID/GID 范围配置
UID_MIN=1000
UID_MAX=65000
GID_MIN=1000
GID_MAX=65000

# JWT 配置
JWT_SECRET="xK8hL9mP2qR5sV7wY4zN6bE3tA1cF9gJ2dM4nP6rS8uV"

# 开发模式配置
# ⚠️ 警告：开发模式仅用于开发测试，会使用模拟数据绕过 LDAP 和 Slurm
# 生产环境必须设置为 false，否则系统将不会连接真实的 LDAP 和 Slurm
# 
# 🔧 当前设置: DEV_MODE=false (生产模式 - 使用真实数据)
# 📝 说明: 所有接口将直接连接LDAP和Slurm API，不使用模拟数据
# 🚀 认证: 需要提供有效的JWT token才能访问API
DEV_MODE=false
# DEV_USER=admin
# DEV_USER_UID=1000
# DEV_USER_IS_ADMIN=true

# 服务器配置
SERVER_PORT=8080

# CORS 配置
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Slurm REST API 配置
SLURM_REST_URL=http://192.168.5.250:30099
# Slurm REST API 版本配置
# 可选值: v0.0.40, v0.0.41, v0.0.42, v0.0.43, v0.0.44
SLURM_API_VERSION=v0.0.43

# Slurm 管理员用户（用于账户/用户/关联的写操作，需要有 Administrator 权限）
SLURM_ADMIN_USER=root

# Slurm JWT 密钥配置（必需）
# 用于动态生成每个用户的Slurm REST API token
# 这个密钥必须与Slurm服务器上的 /etc/slurm/jwt_hs256.key 内容一致
# 
# 获取密钥的方法：
# 1. 从Slurm服务器复制: scp root@192.168.5.250:/etc/slurm/jwt_hs256.key ./
# 2. 将密钥内容粘贴到下面（去除换行符）
# 
# 当前配置的密钥（已从Slurm服务器获取）：
SLURM_JWT_KEY=YEoqs4yNYiqeL6X4CHmAokT0cm+yBr7qUT1bxHGUMYI=

# Token有效期（秒）
# 默认86400秒（24小时）
# 每次用户登录时，系统会自动为该用户生成有效期为此时长的token
# 建议设置为24小时或更长，避免频繁过期
SLURM_JWT_LIFESPAN=86400

# Web Shell 配置
# 节点配置 (JSON格式 - 必须是单行)
WEBSHELL_NODES=[{"name":"ln0","host":"192.168.5.250","port":31277,"description":"登录节点","enabled":true},{"name":"ln2","host":"192.168.5.251","port":22,"description":"计算节点1","enabled":true},{"name":"ln3","host":"192.168.5.252","port":22,"description":"计算节点2","enabled":false}]

# Web Shell 会话超时时间（分钟）
WEBSHELL_SESSION_TIMEOUT=30

# Web Shell 日志保留天数
WEBSHELL_LOG_RETENTION_DAYS=30

# 用户Home目录基础路径
# 用于作业提交时的工作目录
# 实际路径为: HOME_BASE_PATH/<username>
HOME_BASE_PATH=/fs/home

# AI 问答配置
# 支持 OpenAI 兼容接口（OpenAI / DeepSeek / 通义千问 等）
AI_API_URL=https://chat.tianhe-tech.com/v1/chat/completions
AI_API_KEY=vnwazRGDNiMDbxyj97i3UBpzKVLhj0VYdxzqbt1a2JdexqgB
AI_MODEL=MiniMax-2.5
AI_SYSTEM_PROMPT=你是一个 HPC 高性能计算集群的智能助手，帮助用户解答 Slurm 作业调度、集群使用、脚本编写等问题。回答简洁专业。

# 日志文件路径（默认 slurm-web.log，相对于后端运行目录）
LOG_FILE=slurm-web.log
