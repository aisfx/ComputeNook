# LDAP 配置
LDAP_HOST=192.168.5.250
LDAP_PORT=30833
LDAP_USE_SSL=false
LDAP_SKIP_VERIFY=false
LDAP_BIND_DN=cn=Manager,dc=thhpc,dc=cn
LDAP_BIND_PASSWORD=secret
LDAP_BASE_DN=dc=thhpc,dc=cn
LDAP_USER_BASE_DN=ou=people,dc=thhpc,dc=cn
LDAP_GROUP_BASE_DN=ou=group,dc=thhpc,dc=cn

# UID/GID 范围配置
UID_MIN=1000
UID_MAX=65000
GID_MIN=1000
GID_MAX=65000

# JWT 配置
JWT_SECRET="xK8hL9mP2qR5sV7wY4zN6bE3tA1cF9gJ2dM4nP6rS8uV"

# 开发模式配置
# ⚠️ 警告：开发模式仅用于开发测试，会使用模拟数据绕过 LDAP 和 Slurm
# 生产环境必须设置为 false，否则系统将不会连接真实的 LDAP 和 Slurm
DEV_MODE=false
DEV_USER=admin
DEV_USER_UID=1000
DEV_USER_IS_ADMIN=false

# 服务器配置
SERVER_PORT=8080

# CORS 配置
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Slurm REST API 配置
# 注意：SLURM_REST_TOKEN 会过期，需要定期更新
# 生成新 token: scontrol token lifespan=3600
# Token 过期会导致 "authentication error" 错误
SLURM_REST_URL=http://192.168.5.250:30099
SLURM_REST_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJleHAiOjE3NzI1NDAwNDgsImlhdCI6MTc3MjQ1MzY0OCwic3VuIjoicm9vdCJ9.t9CUVCnIO9n1uW7v2alEet6HXx3mgA0TkUqK7DvIujc
# Slurm REST API 版本配置
# 可选值: v0.0.40, v0.0.41, v0.0.42, v0.0.43, v0.0.44
# 不同版本的API端点可能有所不同
SLURM_API_VERSION=v0.0.40
